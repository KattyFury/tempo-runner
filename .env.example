# Copy thành .env cho chạy local. TRÊN GITHUB ACTIONS: đặt các biến này ở Settings > Secrets.
# Private key của ví Tempo (chỉ nạp ~$5, coi như ví cháy được). Bỏ trống nếu chạy trên VPS đã login sẵn.
TEMPO_PRIVATE_KEY=

# mock = test miễn phí (không gọi mạng) | live = gọi thật tốn USDC
MODE=mock

# Đường dẫn binary tempo-request (Actions/VPS). Mặc định lấy trên PATH.
TEMPO_BIN=tempo-request

# Ngân sách: ~$5/tháng ÷ 30
DAILY_CAP=0.16

# Mock: chạy bao nhiêu lượt liên tiếp để xem log
MOCK_ITERS=15
# Mock: ép các service id này luôn fail (test logic gạch), phân tách bằng dấu phẩy
MOCK_FAIL=
